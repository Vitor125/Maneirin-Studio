rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /products/{productId} {
      allow read: if true;
      allow write, delete: if request.auth != null;
    }
    match /schedules/{scheduleId} {
      allow read: if true;
      allow write, delete: if request.auth != null;
    }
  }
}