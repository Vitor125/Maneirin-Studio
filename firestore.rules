rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserRole() {
      let doc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return doc != null ? doc.data.role : 'none';
    }
    
    function isAdmin() {
      return isAuthenticated() && getUserRole() in ['admin', 'Admin', 'ADMIN'];
    }
    
    function isBarberOrAdmin() {
      return isAuthenticated() && getUserRole() in ['admin', 'Admin', 'ADMIN', 'barber', 'Barber', 'BARBER'];
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update, delete: if isAdmin() || request.auth.uid == userId;
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isBarberOrAdmin();
    }

    match /schedules/{scheduleId} {
      allow read: if true;
      allow write: if isBarberOrAdmin();
    }
  }
}